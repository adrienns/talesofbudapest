SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
OPENROUTER_API_KEY=
# Structured JSON request logs (set to 0 only for local noise suppression; never logs prompts or keys)
OPENROUTER_LOGS=1
# LLM script generation — default: meta-llama/llama-3.1-8b-instruct
OPENROUTER_MODEL=
# Historian narrative enrichment — default: OPENROUTER_MODEL
OPENROUTER_HISTORIAN_MODEL=
# Knowledge-graph extraction — default: google/gemma-3-27b-it (paid fallback)
KG_EXTRACT_MODEL=
# Restricted-book extraction model override (normally leave blank to use the cheap-first ladder)
KG_RESTRICTED_EXTRACT_MODEL=
# Hard conservative spend ceiling per restricted-book extraction invocation (default: USD 1.00)
KG_EXTRACTION_MAX_COST_USD=1.00
# Audio tour script generation — default: OPENROUTER_MODEL
OPENROUTER_AUDIO_MODEL=
# Optional paid OpenRouter TTS override. Direct Gemini is the default runtime provider.
OPENROUTER_TTS_MODEL=
# Optional OpenRouter TTS voice override.
OPENROUTER_TTS_VOICE=
# Default narration provider: direct Gemini Developer API.
# Create a Google AI Studio key and keep billing disabled to stay on the free tier.
GEMINI_API_KEY=
# Defaults: gemini-3.1-flash-tts-preview and the warm Sulafat voice.
GEMINI_TTS_MODEL=
GEMINI_TTS_VOICE=
# Conservative free-tier pacing; set 0 only when the project's active quota permits it.
GEMINI_TTS_REQUEST_INTERVAL_MS=31000
DATABASE_URL=
ORS_API_KEY=
# Bearer secret for /api/internal/narrative-jobs/run recovery invocations.
NARRATIVE_WORKER_SECRET=
